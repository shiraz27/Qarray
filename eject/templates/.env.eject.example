# ============================================================================
# Eject Kit configuration. Copy to eject/.env.eject and fill in.
# Never commit eject/.env.eject — it contains service-role keys.
# ============================================================================

# --- SOURCE: the current Lovable Cloud project (read-only credentials) ----
# All four values are already known to Lovable; you can copy them from
# Project Settings -> Lovable Cloud, or from supabase/config.toml + .env.
SOURCE_SUPABASE_URL="https://xwqmdhnuthprzfbyoxlb.supabase.co"
SOURCE_SUPABASE_PROJECT_REF="xwqmdhnuthprzfbyoxlb"
SOURCE_SUPABASE_ANON_KEY=""           # eyJ... (publishable)
SOURCE_SUPABASE_SERVICE_ROLE_KEY=""   # eyJ... (SECRET — required to dump auth + storage)
SOURCE_SUPABASE_DB_URL=""             # postgres://postgres:<pwd>@db.xwqmdhnuthprzfbyoxlb.supabase.co:5432/postgres

# --- TARGET (cloud) -------------------------------------------------------
# Required when --target=cloud. Create at https://supabase.com/dashboard.
# Personal access token from https://supabase.com/dashboard/account/tokens.
SUPABASE_ACCESS_TOKEN=""
TARGET_ORG_ID=""                      # org the new project lives under
TARGET_PROJECT_NAME="my-app-ejected"
TARGET_REGION="eu-central-1"          # https://supabase.com/docs/guides/platform/regions
TARGET_DB_PASSWORD=""                 # postgres user password for the new project

# Filled in by 60_provision_cloud.sh — leave blank.
TARGET_SUPABASE_PROJECT_REF=""
TARGET_SUPABASE_URL=""
TARGET_SUPABASE_ANON_KEY=""
TARGET_SUPABASE_SERVICE_ROLE_KEY=""
TARGET_SUPABASE_DB_URL=""

# --- TARGET (self-hosted) -------------------------------------------------
# Required when --target=self-hosted. See templates/docker-compose.self-hosted.yml.
SELF_HOSTED_HOST="http://localhost:8000"
SELF_HOSTED_DB_PASSWORD="postgres"
SELF_HOSTED_JWT_SECRET=""             # 32+ chars; generated by 62_provision_self_hosted.sh if blank

# --- Edge function third-party secrets ------------------------------------
# These literally cannot be read back from Lovable Cloud. Paste them here so
# 74_push_secrets.sh can upload them to the new project.
OPENROUTER_API_KEY=""
ARCHIVE_ORG_ACCESS_KEY=""
ARCHIVE_ORG_SECRET_KEY=""
# OLLAMA_BASE_URL is optional; leave blank to skip.
OLLAMA_BASE_URL=""
# LOVABLE_API_KEY is managed by Lovable and won't work outside it. Replace
# the AI provider in your edge functions before cutover (see RUNBOOK.md §8).
GOOGLE_GENERATIVE_AI_API_KEY=""
*** End Patch